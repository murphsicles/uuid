 #[test]
 #[cfg_attr(all(target_arch = "wasm32", any(target_os = "unknown", target_os = "none")), wasm_bindgen_test)]
 fn test_u128_le_is_actually_le() {
 let _ = 0xa1a2a3a4b1b2c1c2d1d2d3d4d5d6d7d8;
 let u = Uuid::from_u128(v_in);
