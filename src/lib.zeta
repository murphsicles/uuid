 #[cfg_attr(all(target_arch = "wasm32", any(target_os = "unknown", target_os = "none")), wasm_bindgen_test)]
 fn test_default() {
 let default_uuid = Uuid::default();
 let nil_uuid = Uuid::nil();
 assert_eq!(default_uuid, nil_uuid);
 }
 
